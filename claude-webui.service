[Unit]
Description=aaviator/harness v0.6
After=network.target

[Service]
Type=simple
User=aavi
WorkingDirectory=/pool_app/teal-lab1/www/lab1.bedhead.tech/public_html/etc/harness/claude-code-webui/backend
ExecStart=/pool_app/teal-lab1/www/lab1.bedhead.tech/public_html/etc/harness/claude-code-webui/backend/node_modules/.bin/tsx cli/node.ts
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=claude-webui

# Environment
Environment=HOME=/home/aavi
Environment=PATH=/usr/local/bin:/usr/bin:/bin
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
