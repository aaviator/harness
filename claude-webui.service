# Copy to /etc/systemd/system/ and replace <YOUR_USER> and <INSTALL_DIR>
# Then: systemctl daemon-reload && systemctl enable --now claude-webui

[Unit]
Description=aaviator/harness
After=network.target

[Service]
Type=simple
User=<YOUR_USER>
WorkingDirectory=<INSTALL_DIR>/backend
ExecStart=<INSTALL_DIR>/backend/node_modules/.bin/tsx cli/node.ts
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=claude-webui

# Environment
Environment=HOME=/home/<YOUR_USER>
Environment=PATH=/usr/local/bin:/usr/bin:/bin
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
