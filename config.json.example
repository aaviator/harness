{
  "port": 19090,
  "host": "127.0.0.1",
  "debug": false,
  "defaultDir": "/home/user/projects",
  "allowSudo": false,
  "tmuxIdleHours": 4,
  "convPageSize": 10,
  "defaultModel": "claude-sonnet-4-6",
  "models": ["claude-sonnet-4-6", "claude-opus-4-6", "claude-haiku-4-5-20251001"],

  "corsOrigins": ["https://your-domain.com", "http://localhost:3000"],

  "auth": true,
  "authUsername": "admin",
  "authPasswordHash": "GENERATE_WITH: node -e \"require('bcryptjs').hash('YOUR_PASSWORD', 10, (e,h) => console.log(h))\"",

  "env": {
    "NODE_TLS_REJECT_UNAUTHORIZED": "0",
    "ANTHROPIC_SMALL_FAST_MODEL": "claude-haiku-4-5-20251001"
  }
}
